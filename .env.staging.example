APP_NAME="VAS Partners (Staging)"
APP_ENV=staging
APP_KEY=
APP_DEBUG=true
APP_URL=https://vaspartnersportal.ethiotelecom.et:8443
FRONTEND_URL=https://vaspartnersportal.ethiotelecom.et:8443
MAX_OPEN_TICKETS=1

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Overridden by compose.staging.yml to container service names.
DB_CONNECTION=pgsql
DB_HOST=pgbouncer
DB_PORT=5432
DB_DATABASE=vaspartners
DB_USERNAME=vas
DB_PASSWORD=secret
DB_EMULATE_PREPARES=false

SESSION_DRIVER=redis
SESSION_LIFETIME=120

CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

SANCTUM_STATEFUL_DOMAINS=vaspartnersportal.ethiotelecom.et:8443
TRUSTED_PROXIES=*

# Fayda / eSignet — register this redirect on the Fayda client
FAYDA_CLIENT_ID=
FAYDA_REDIRECT_URI=https://vaspartnersportal.ethiotelecom.et:8443/callback
FAYDA_AUTH_URL=https://esignet.ida.fayda.et/authorize
FAYDA_TOKEN_URL=https://esignet.ida.fayda.et/v1/esignet/oauth/v2/token
FAYDA_USERINFO_URL=https://esignet.ida.fayda.et/v1/esignet/oidc/userinfo
FAYDA_PRIVATE_KEY=
FAYDA_ALG=RS256
FAYDA_ASSERTION_TYPE=urn:ietf:params:oauth:client-assertion-type:jwt-bearer
FAYDA_EXPIRATION_TIME=15

FILAMENT_SPA=false
DEFAULT_RENEWAL_INTERVAL=yearly

FILAMENT_IMPERSONATE_REDIRECT=/admin
FILAMENT_IMPERSONATE_BANNER_STYLE=dark

SMS_ENDPOINT=https://smsgw.ethiotelecom.et/bl/index.php?receiver=
SMS_ENABLED=true

VAS_SEED_ON_START=true
