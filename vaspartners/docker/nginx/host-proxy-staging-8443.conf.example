# ============================================================================
# OPTIONAL Host Nginx — VAS Partners staging on :8443
# ============================================================================
#
# Prefer the default staging setup: Docker nginx terminates Tele SSL and
# binds host port 8443 directly (see compose.staging.yml). Use THIS file only
# if you want host Nginx to terminate SSL (same pattern as mvasportal :443).
#
# CRITICAL: Do NOT change /etc/nginx/conf.d/mvasportal.conf — production
# vaspartnersportal.ethiotelecom.et:443 must keep proxying to :30011.
#
# ACCESS: https://vaspartnersportal.ethiotelecom.et:8443
#
# Install:
#   sudo cp docker/nginx/host-proxy-staging-8443.conf.example \
#     /etc/nginx/conf.d/vaspartners-staging-8443.conf
#   # then change compose nginx ports from "8443:443" to "30012:80"
#   # and switch default.staging.conf to listen 80 only
#   sudo nginx -t && sudo systemctl reload nginx
# ============================================================================

server {
    listen 8443 ssl;
    http2 on;
    server_name vaspartnersportal.ethiotelecom.et www.vaspartnersportal.ethiotelecom.et;

    ssl_certificate     /etc/nginx/ssl/fullchain-wildcard.crt;
    ssl_certificate_key /etc/nginx/ssl/ethiotelecom-wildcard.key;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    add_header X-Content-Type-Options nosniff always;
    add_header X-Frame-Options SAMEORIGIN always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    client_max_body_size 50M;
    large_client_header_buffers 4 64k;

    location / {
        proxy_pass http://127.0.0.1:30012;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Port  8443;
        proxy_buffer_size 128k;
        proxy_buffers 4 256k;
        proxy_busy_buffers_size 256k;
        proxy_hide_header Content-Security-Policy;
    }
}
