APP_NAME="VAS Partners"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
MAX_OPEN_TICKETS=1

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Docker Compose overrides DB_HOST/REDIS_HOST inside containers.
# From the host (optional): postgres :5433, pgbouncer :6432, redis :6380
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=vaspartners
DB_USERNAME=vas
DB_PASSWORD=secret
DB_EMULATE_PREPARES=true

SESSION_DRIVER=redis
SESSION_LIFETIME=120

CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_PASSWORD=null

SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

# Fayda / eSignet — local registered redirect is the Next.js bridge page
FAYDA_CLIENT_ID=
FAYDA_REDIRECT_URI=http://localhost:3000/callback
FAYDA_AUTH_URL=https://esignet.ida.fayda.et/authorize
FAYDA_TOKEN_URL=https://esignet.ida.fayda.et/v1/esignet/oauth/v2/token
FAYDA_USERINFO_URL=https://esignet.ida.fayda.et/v1/esignet/oidc/userinfo
FAYDA_PRIVATE_KEY=
FAYDA_ALG=RS256
FAYDA_ASSERTION_TYPE=urn:ietf:params:oauth:client-assertion-type:jwt-bearer
FAYDA_EXPIRATION_TIME=15

FILAMENT_SPA=false
DEFAULT_RENEWAL_INTERVAL=yearly
